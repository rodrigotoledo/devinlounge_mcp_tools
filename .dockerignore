# .dockerignore - Files to exclude from Docker build context
# Reduces image size by excluding unnecessary files from COPY operations

# Version Control
.git
.gitignore
.gitattributes
.github/
.gitlab-ci.yml
.circleci/

# Documentation (included separately if needed)
docs/
*.md
README.md
LICENSE

# IDE & Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Python
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/

# Ruby
.bundle/
vendor/bundle/
Gemfile.lock

# Elixir/Mix
_build/
deps/

# Docker
docker-compose*.yml
.dockerignore
Dockerfile.dev

# Environment
.env
.env.local
.env.*.local

# Build artifacts
dist/
build/
.next/
.turbo/
tmp/
temp/
coverage/

# OS
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db

# CI/CD
.gitlab/
.travis.yml
appveyor.yml

# Logs
logs/
*.log

# Keep important files
!.env.example
!Gemfile.lock
!package-lock.json
