# Copie para `.env` na raiz do repositório (mesma pasta que `docker-compose.yml`).
# O Docker Compose usa este arquivo só para substituir ${VAR} no compose — não entra nos containers
# exceto onde você referencia explicitamente.
#
#   cp .env.example .env
#   ./scripts/sync-env-from-example.sh

# Portas publicadas no host
# Se o compose falhar com "Bind for 0.0.0.0:5432 failed: port is already allocated", use outra porta (ex. 5433).
# Serviços na rede Docker continuam usando hostname `db` e porta 5432 por dentro.
POSTGRES_PORT=5432
REDIS_PORT=6379
API_PORT=8000
FULLSTACK_PORT=3000

# Modo da API no container (development = --reload)
ENV=development

# Uvicorn: em bind mount, polling costuma ser necessário no Docker Desktop
WATCHFILES_FORCE_POLLING=true

# Rails fullstack / fullstack-worker — development: Compose injeta FULLSTACK_* → DATABASE_* no container.
# Production (Kamal etc.): defina DATABASE_URL e opcional DATABASE_CACHE_URL no runtime, não estes FULLSTACK_*.
# FULLSTACK_DATABASE_HOST=db
# FULLSTACK_DATABASE_PORT=5432
# FULLSTACK_DATABASE_USERNAME=hardhat
# FULLSTACK_DATABASE_PASSWORD=hardhat
# FULLSTACK_DATABASE_NAME=hardhat
# FULLSTACK_DATABASE_CACHE_NAME=hardhat_cache
# FULLSTACK_DATABASE_APPLICATION_NAME=hardhat_fullstack
# Testes locais (fora do Compose): DATABASE_TEST_NAME, DATABASE_CACHE_TEST_NAME

# Redis para Rails: Action Cable e Sidekiq (índice /1; a API costuma usar /0). Cache de fragmento = Solid Cache (Postgres).
# FULLSTACK_REDIS_URL=redis://redis:6379/1

# Incluir serviços com `profiles` no Compose (ex.: Guard RSpec em `fullstack-guard`):
# COMPOSE_PROFILES=guard
