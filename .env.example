# Root Environment Configuration
# Copy to `.env` in the repository root (same directory as `docker-compose.yml`)
# Use ./scripts/sync-env-from-example.sh to create/update all service .env files

# ============================================================================
# INFRASTRUCTURE — PostgreSQL
# ============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=app_user
POSTGRES_PASSWORD=dev_password
POSTGRES_DATABASE=app_db

# Cache database for Rails Solid Cache (optional; if not set, uses `<db>_cache`)
POSTGRES_CACHE_DATABASE=app_db_cache

# ============================================================================
# INFRASTRUCTURE — Redis
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
# Redis URL format: redis://host:port/db-index (Rails uses /1, FastAPI uses /0)
REDIS_URL=redis://redis:6379/1

# ============================================================================
# PORTS — Published to Host
# ============================================================================
# Frontend ports (host → container)
EXPO_PORT=8081                 # Expo dev server (host-only; not in Compose)
NEXTJS_PORT=3000
REACT_PORT=5173                # Vite dev server
RAILS_PORT=3000                # Rails web server (can conflict with Next.js; use separate port if running both)

# Backend API ports
NESTJS_PORT=3001
FASTAPI_PORT=8000
PHOENIX_PORT=4000

# Database & cache ports
POSTGRES_PUBLISH_PORT=5432
REDIS_PUBLISH_PORT=6379

# ============================================================================
# ENVIRONMENT & DEBUG
# ============================================================================
# Node services
NODE_ENV=development
NODE_LOG_LEVEL=info

# Python services
PYTHON_ENV=development
LOG_LEVEL=INFO

# Ruby on Rails
RAILS_ENV=development
RAILS_LOG_LEVEL=debug

# Elixir/Phoenix
MIX_ENV=dev
PHOENIX_LOG_LEVEL=info

# Docker build args
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# ============================================================================
# FILE WATCHING & POLLING
# ============================================================================
# Force polling for file watcher (Docker Desktop / WSL2 usually needs this)
WATCHFILES_FORCE_POLLING=true

# ============================================================================
# FRONTEND — Expo (React Native)
# ============================================================================
# Runs on host; not managed by docker-compose
EXPO_CLI_SOCKET=true
EXPO_DEBUG=false

# ============================================================================
# FRONTEND — Next.js
# ============================================================================
# API endpoint for frontend (set in web-nextjs/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ============================================================================
# FRONTEND — React SPA
# ============================================================================
VITE_API_URL=http://localhost:3001

# ============================================================================
# BACKEND — NestJS
# ============================================================================
# Database connection (NestJS container uses POSTGRES_* above via docker-compose.yml)
NESTJS_DATABASE_HOST=db
NESTJS_DATABASE_PORT=5432
NESTJS_DATABASE_USER=app_user
NESTJS_DATABASE_PASSWORD=dev_password
NESTJS_DATABASE_NAME=app_db

# Redis (NestJS uses /0 by default; adjust if needed)
NESTJS_REDIS_URL=redis://redis:6379/0
NESTJS_JWT_SECRET=dev-secret-key-change-in-production
NESTJS_JWT_EXPIRES_IN=7d

# CORS
NESTJS_CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ============================================================================
# BACKEND — FastAPI
# ============================================================================
API_DATABASE_URL=postgresql+asyncpg://app_user:dev_password@db:5432/app_db
API_REDIS_URL=redis://redis:6379/0
API_SECRET_KEY=dev-secret-key-change-in-production
API_ALGORITHM=HS256
API_TOKEN_EXPIRE_MINUTES=1440

# ============================================================================
# BACKEND — Rails
# ============================================================================
# These are injected into fullstack/fullstack-worker containers as DATABASE_* / REDIS_*
FULLSTACK_DATABASE_HOST=db
FULLSTACK_DATABASE_PORT=5432
FULLSTACK_DATABASE_USER=app_user
FULLSTACK_DATABASE_PASSWORD=dev_password
FULLSTACK_DATABASE_NAME=app_db
FULLSTACK_DATABASE_CACHE_NAME=app_db_cache

FULLSTACK_REDIS_URL=redis://redis:6379/1

# Session encryption & security
FULLSTACK_SECRET_KEY_BASE=dev-secret-very-long-random-string-change-in-production
FULLSTACK_SESSION_SECRET=dev-session-secret

# Email delivery (development)
FULLSTACK_SMTP_HOST=mailhog         # Or use ActionMailer in-memory / :test adapter
FULLSTACK_SMTP_PORT=1025
FULLSTACK_SMTP_USERNAME=
FULLSTACK_SMTP_PASSWORD=

# ============================================================================
# BACKEND — Phoenix / Elixir
# ============================================================================
PHOENIX_DATABASE_URL=ecto://app_user:dev_password@db:5432/app_db
PHOENIX_SECRET_KEY_BASE=dev-secret-very-long-random-string-change-in-production
PHOENIX_SIGNING_SALT=dev-signing-salt
PHOENIX_LIVE_VIEW_SIGNING_SALT=dev-live-view-salt

# ============================================================================
# OPTIONAL — Docker Compose Profiles
# ============================================================================
# Uncomment to enable specific services (e.g., Guard RSpec auto-test watcher)
# COMPOSE_PROFILES=guard
# COMPOSE_PROFILES=debug,monitoring

# ============================================================================
# NOTES
# ============================================================================
# 1. Database connections inside containers use `db` (service name in docker-compose.yml)
#    Host connections use POSTGRES_HOST (localhost or IP)
#
# 2. Redis indexing:
#    - Rails (fullstack-worker): /1 (Action Cable, Sidekiq)
#    - FastAPI: /0 (session, rate limiting)
#    - NestJS: /0 (session, cache)
#    - Phoenix: /2 or higher (keep separate from others)
#
# 3. Ports published to host:
#    - If port already in use, change POSTGRES_PUBLISH_PORT, REDIS_PUBLISH_PORT, or service ports
#    - Services inside containers still use default ports (5432, 6379, 3000, etc.)
#
# 4. Secrets:
#    - All *_SECRET* and *_PASSWORD* values below are EXAMPLES only
#    - Change these in production to strong, randomly generated values
#    - Store real secrets in .env (local), CI/CD environment variables, or secrets manager (prod)
#
# 5. Create service-specific .env files:
#    ./scripts/sync-env-from-example.sh
#    Generates: web-nextjs/.env.local, backend-nestjs/.env, backend-rails/.env, etc.
